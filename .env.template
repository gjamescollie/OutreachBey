# ─── CLIENT IDENTITY ──────────────────────────────────────────────────────────
CLIENT_ID=

# ─── DASHBOARD ────────────────────────────────────────────────────────────────
# Password for the web dashboard on :3000. REQUIRED — set a strong, unique value.
# If left blank the agent refuses to start (it will NOT fall back to a default).
# Wrap the value in double quotes so symbols are read correctly — an unquoted
# '#' or a space truncates the value (everything after '#' is treated as a
# comment). Example: DASHBOARD_PASSWORD="my#strong!pass word"
DASHBOARD_PASSWORD=

# ─── AI PROVIDER ──────────────────────────────────────────────────────────────
# Options: openrouter | anthropic | openai | google
AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-haiku-4-5

# ─── API KEYS (fill in the one matching AI_PROVIDER) ──────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── PROXY (optional but recommended for cloud deployments) ───────────────────
# Use a static residential proxy to avoid Meta IP-based bans.
# Format: http://user:pass@ip:port
# Providers: IPRoyal, Oxylabs, Bright Data, Smartproxy
# Must be STATIC (not rotating) — rotating IPs break WhatsApp sessions.
PROXY_URL=
